<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
  </head>
  <body>
    <h1><%= title %></h1>

    <a href="/new">Add a new message</a>
    
    <h2>Messages:</h2>

    <% for (let message of messages) { %>
        <div class="message-box">
            <p><%= message.user %>: <%= message.text %></p>
            <p><%= message.added %></p>
        </div>
    <% } %>
  </body>
</html>
